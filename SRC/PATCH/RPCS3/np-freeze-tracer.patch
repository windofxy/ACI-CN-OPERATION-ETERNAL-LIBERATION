diff --git a/rpcs3/Emu/NP/freeze_tracer.h b/rpcs3/Emu/NP/freeze_tracer.h
new file mode 100644
index 000000000..92b56031f
--- /dev/null
+++ b/rpcs3/Emu/NP/freeze_tracer.h
@@ -0,0 +1,44 @@
+#pragma once
+
+#include <atomic>
+#include <cstdint>
+
+// Freeze-tracer diagnostics. Pure-observation counters shared across the NP, sysutil and P2PS
+// translation units. Every probe is a single relaxed atomic bump; the P2PS tcp_timeout_monitor
+// reads these counters and emits edge-triggered / rate-limited log lines. No probe takes a lock,
+// allocates, or sits on a data-steered branch, so removing any probe is behaviour neutral.
+namespace freeze_tracer
+{
+	// Heartbeats: monotonic ticks. A counter advances only while its owner thread makes progress;
+	// the monitor owns the clock and checks "did this advance since I last looked N ms ago".
+	inline std::atomic<std::uint64_t> g_sig_heartbeat{0};   // signaling handler loop
+	inline std::atomic<std::uint64_t> g_pump_heartbeat{0};  // cellSysutilCheckCallback
+
+	// Disconnect-event markers: enqueued under the signaling data_mutex, delivered after release.
+	// enqueued > delivered while signaling is stale means the callback pump is wedged.
+	inline std::atomic<std::uint64_t> g_dead_enqueued{0};
+	inline std::atomic<std::uint64_t> g_dead_delivered{0};
+	inline std::atomic<std::uint64_t> g_estab_enqueued{0};
+	inline std::atomic<std::uint64_t> g_estab_delivered{0};
+
+	// Getter call counts. The monitor flushes a per-second rate; the getters only increment.
+	inline std::atomic<std::uint64_t> g_getter_sig2{0};
+	inline std::atomic<std::uint64_t> g_getter_sig{0};
+	inline std::atomic<std::uint64_t> g_getter_member{0};
+
+	inline void beat_sig() { g_sig_heartbeat.fetch_add(1, std::memory_order_relaxed); }
+	inline void beat_pump() { g_pump_heartbeat.fetch_add(1, std::memory_order_relaxed); }
+
+	inline void mark_enqueue(bool is_dead)
+	{
+		(is_dead ? g_dead_enqueued : g_estab_enqueued).fetch_add(1, std::memory_order_relaxed);
+	}
+	inline void mark_deliver(bool is_dead)
+	{
+		(is_dead ? g_dead_delivered : g_estab_delivered).fetch_add(1, std::memory_order_relaxed);
+	}
+
+	inline void getter_sig2() { g_getter_sig2.fetch_add(1, std::memory_order_relaxed); }
+	inline void getter_sig() { g_getter_sig.fetch_add(1, std::memory_order_relaxed); }
+	inline void getter_member() { g_getter_member.fetch_add(1, std::memory_order_relaxed); }
+}
