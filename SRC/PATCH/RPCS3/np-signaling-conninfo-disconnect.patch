diff --git a/rpcs3/Emu/Cell/Modules/sceNp2.cpp b/rpcs3/Emu/Cell/Modules/sceNp2.cpp
index 1fbef4d74..2f8b02a27 100644
--- a/rpcs3/Emu/Cell/Modules/sceNp2.cpp
+++ b/rpcs3/Emu/Cell/Modules/sceNp2.cpp
@@ -716,6 +716,31 @@ error_code sceNpMatching2SignalingGetConnectionInfo(
 	if (!si)
 		return SCE_NP_SIGNALING_ERROR_CONN_NOT_FOUND;
 
+	// A peer whose P2PS link has timed out is marked INACTIVE by
+	// signaling_handler::force_disconnect_by_addr, but its signaling_info is kept
+	// (npid->conn_id mapping and the si both survive). The game polls this getter
+	// to track peer liveness and only reacts to a negative return, so reporting
+	// stale "connected" info for a dead peer hides the disconnect and can hang a
+	// mission that waits on that peer. Report the connection as gone instead.
+	// [FREEZE-DIAG] D2: edge-triggered per (room, member). Logs once when the getter
+	// returns CONN_NOT_FOUND for an INACTIVE peer so telemetry can confirm the getter
+	// is honest during a freeze. Also logs once if a previously-INACTIVE member flips
+	// back to ACTIVE (catches a flapping reconnect that might defeat the honesty fix).
+	{
+		using room_member_key = std::pair<SceNpMatching2RoomId, SceNpMatching2RoomMemberId>;
+		static shared_mutex s_d2_mtx;
+		static std::set<room_member_key> s_d2_inactive_seen;
+		std::lock_guard lock(s_d2_mtx);
+		if (si->conn_status == SCE_NP_SIGNALING_CONN_STATUS_INACTIVE)
+		{
+			if (s_d2_inactive_seen.emplace(roomId, memberId).second)
+				sceNp2.notice("[FREEZE-DIAG] D2: GetConnectionInfo returning CONN_NOT_FOUND for INACTIVE member(%d) of room(%d)", memberId, roomId);
+			return SCE_NP_SIGNALING_ERROR_CONN_NOT_FOUND;
+		}
+		if (s_d2_inactive_seen.erase({roomId, memberId}))
+			sceNp2.notice("[FREEZE-DIAG] D2: GetConnectionInfo member(%d) of room(%d) flipped back to ACTIVE (was INACTIVE)", memberId, roomId);
+	}
+
 	switch (code)
 	{
 		case SCE_NP_SIGNALING_CONN_INFO_RTT:
