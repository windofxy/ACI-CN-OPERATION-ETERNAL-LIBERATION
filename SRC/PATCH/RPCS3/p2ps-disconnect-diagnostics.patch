 {
 	cellSysutil.trace("cellSysutilCheckCallback()");
 
+	// [FREEZE-DIAG] D1: rate-limited heartbeat. During a mid-mission freeze, if this
+	// keeps printing alongside the GetNetworkTime tail the frame loop is alive and
+	// callbacks are being delivered (motivating a callback-based fix). If it stops,
+	// the loop parked in a sub-call before returning here. At most once per second.
+	{
+		static atomic_t<u64> s_d1_last_ns{0};
+		const u64 now_ns = static_cast<u64>(
+			std::chrono::duration_cast<std::chrono::nanoseconds>(
+				steady_clock::now().time_since_epoch()).count());
+		const u64 prev = s_d1_last_ns.load();
+		if (now_ns - prev >= 1'000'000'000ull && s_d1_last_ns.compare_and_swap(prev, now_ns) == prev)
+			cellSysutil.notice("[FREEZE-DIAG] D1: CheckCallback pumping");
+	}
+
+	// [FREEZE-DIAG] D5: one-shot snapshot when NP goes silent for >8s while this pump
+	// stays alive. Captures pending matching2 requests and room_event_cb state to
+	// identify what the game is waiting on.
+	{
+		static atomic_t<u32> s_d5_latched{0};
+		const u64 now_ns = static_cast<u64>(
+			std::chrono::duration_cast<std::chrono::nanoseconds>(
+				steady_clock::now().time_since_epoch()).count());
+		const u64 last = np::np_handler::last_np_progress_ns();
+		if (last != 0)
+		{
+			const bool stalled = (now_ns - last >= 8'000'000'000ull);
+			if (!stalled)
+			{
+				// Re-arm so a later freeze fires again
+				s_d5_latched.store(0);
+			}
+			else if (s_d5_latched.compare_and_swap(0, 1) == 0)
+			{
+				cellSysutil.notice("[FREEZE-DIAG] D5: NP stalled >8s, pump alive; snapshot follows");
+				auto& nph = g_fxo->get<named_thread<np::np_handler>>();
+				const auto reqs = nph.get_pending_requests_snapshot();
+				if (reqs.empty())
+				{
+					cellSysutil.notice("[FREEZE-DIAG] D5: no pending matching2 requests");
+				}
+				else
+				{
+					for (const auto& [req_id, event_type, submitted_ns] : reqs)
+					{
+						const u64 age_ms = submitted_ns ? (now_ns - submitted_ns) / 1'000'000u : 0u;
+						cellSysutil.notice("[FREEZE-DIAG] D5: pending req_id=0x%x event_type=0x%x age_ms=%llu", req_id, event_type, age_ms);
+					}
+				}
+				cellSysutil.notice("[FREEZE-DIAG] D5: room_event_cb %s", nph.has_room_event_cb() ? "registered" : "null");
+			}
+		}
+	}
+
 	auto& cbm = g_fxo->get<sysutil_cb_manager>();
 
 	for (auto&& func : cbm.registered.pop_all())
