+	const error_code res = nph.local_get_room_member_data(roomId, memberId, binattrs_list, member ? member.get_ptr() : nullptr, buf.addr(), bufLen, ctxId);
+
+	// [FREEZE-DIAG] D3: smoking-gun probe. FUN_0074e210 calls this getter first and bails
+	// if it fails. If it SUCCEEDS while signaling is INACTIVE for that member, del_member
+	// never ran (no MemberLeft arrived), the np_cache still holds the member, and the
+	// game loop cannot detect the drop via this early-bail path -- motivating synthesized
+	// MemberLeft as the fix layer. Edge-triggered per (room, member) to avoid spam.
+	if (!res)
+	{
+		auto [npid_res, npid] = nph.local_get_npid(roomId, memberId);
+		if (!npid_res)
+		{
+			auto& sigh = g_fxo->get<named_thread<signaling_handler>>();
+			const auto conn_id_opt = sigh.get_conn_id_from_npid(*npid);
+			if (conn_id_opt)
+			{
+				const auto si = sigh.get_sig_infos(*conn_id_opt);
+				if (si && si->conn_status == SCE_NP_SIGNALING_CONN_STATUS_INACTIVE)
+				{
+					using room_member_key = std::pair<SceNpMatching2RoomId, SceNpMatching2RoomMemberId>;
+					static shared_mutex s_d3_mtx;
+					static std::set<room_member_key> s_d3_seen;
+					std::lock_guard lock(s_d3_mtx);
+					if (s_d3_seen.emplace(roomId, memberId).second)
+						sceNp2.notice("[FREEZE-DIAG] D3: GetRoomMemberDataInternalLocal succeeded for INACTIVE member(%d) of room(%d) -- del_member never ran", memberId, roomId);
+				}
+			}
+		}
+	}
+
+	return res;
