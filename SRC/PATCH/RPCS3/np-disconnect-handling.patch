diff --git a/rpcs3/Emu/NP/np_cache.cpp b/rpcs3/Emu/NP/np_cache.cpp
index 4d70cacaa..c072cd797 100644
--- a/rpcs3/Emu/NP/np_cache.cpp
+++ b/rpcs3/Emu/NP/np_cache.cpp
@@ -109,7 +109,18 @@ namespace np
 			return false;
 		}
 
-		rooms.erase(member_id);
+		// Erase the member from the room's member list. This previously erased from the
+		// rooms map keyed by member_id - a no-op, since member ids are not room ids - which
+		// left the departed member in the room's member list. The member-list getters then
+		// kept returning that member even after its leave callback fired, leaving a "ghost"
+		// slot that was occupied but showed no player. Returning false when the member was
+		// not present also keeps the caller's leave-callback guard idempotent.
+		if (::at32(rooms, room_id).members.erase(member_id) == 0)
+		{
+			np_cache.warning("np_cache::del_member: member(%d) not present in room(%d) (already removed?)", member_id, room_id);
+			return false;
+		}
+
 		return true;
 	}
 
