 	return not_an_error(ppu.gpr[3]);
 }
+
+// Read-only snapshot of all parked PPU threads under lv2 conds. Called during a detected stall;
+// idm::select takes the idm read lock internally. The sleep queue is deliberately read without
+// the cond's mutex (the caller must never block); the queue can mutate underneath, which at worst
+// produces a stale line. Nodes are idm-owned threads, and the walk is capped so a torn view of the
+// list cannot loop the calling thread.
+void freeze_tracer::dump_parked_threads()
+{
+	idm::select<lv2_obj, lv2_cond>([](u32 id, lv2_cond& cond)
+	{
+		u32 walked = 0;
+		for (auto cpu = atomic_storage<ppu_thread*>::load(cond.sq); cpu && walked < 128; cpu = cpu->next_cpu, walked++)
+			sys_cond.notice("[freeze-tracer] park cond=0x%x ppu=0x%x cia=0x%x", id, cpu->id, cpu->cia);
+	});
+}
diff --git a/rpcs3/Emu/Cell/lv2/sys_net/lv2_socket_p2ps.cpp b/rpcs3/Emu/Cell/lv2/sys_net/lv2_socket_p2ps.cpp
