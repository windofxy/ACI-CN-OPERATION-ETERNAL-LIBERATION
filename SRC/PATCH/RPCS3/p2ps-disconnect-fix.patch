+void signaling_handler::force_disconnect_by_addr(u32 addr, u16 port)
+{
+	deferred_work work;
+	{
+	std::lock_guard lock(data_mutex);
+
+	// Prefer an exact addr+port match: two peers behind one public IP share an external
+	// address and differ only by port, so an addr-only match could disconnect the wrong
+	// peer. Fall back to the first addr-only match if no port matches, which preserves the
+	// original behaviour for the common single-peer case and never leaves a dead peer
+	// connected. si->port and the passed port share the same representation - both are
+	// bit_cast<u16, be_t<u16>>(sin_port) of the same peer UDP endpoint (signaling and P2PS
+	// ride the same port) - so a direct == is correct.
+	std::shared_ptr<signaling_info> target;
+	const char* match_kind = "";
+	bool port_matched      = false;
+
+	std::shared_ptr<signaling_info> addr_only_si;
+	const char* addr_only_kind = "";
+
+	for (auto& [conn_id, si] : sig_peers)
+	{
+		if (!si || si->conn_status == SCE_NP_SIGNALING_CONN_STATUS_INACTIVE)
+			continue;
+
+		// Both si->addr and addr are in network byte order (sin_addr.s_addr format).
+		// si->addr is the peer's actual IP (local on LAN, NAT external in production).
+		// RPCN never relays P2PS data.
+		const bool direct_match = (si->addr == addr);
+		const bool mapped_match = (si->mapped_addr != 0 && si->mapped_addr == addr);
+
+		if (!direct_match && !mapped_match)
+			continue;
+
+		const char* kind      = direct_match ? "direct" : "mapped";
+		const bool port_match = (direct_match && si->port == port) || (mapped_match && si->mapped_port == port);
+
+		if (port_match)
+		{
+			target       = si;
+			match_kind   = kind;
+			port_matched = true;
+			break;
+		}
+
+		if (!addr_only_si)
+		{
+			addr_only_si   = si;
+			addr_only_kind = kind;
+		}
+	}
+
+	if (!target && addr_only_si)
+	{
+		target     = addr_only_si;
+		match_kind = addr_only_kind;
+	}
+
+	if (target)
+	{
+		if (port_matched)
+			sign_log.warning("[P2PS] Peer timed out, dropping signaling connection: conn_id %d (%s addr+port match)", target->conn_id, match_kind);
+		else
+			sign_log.warning("[P2PS] Peer timed out, dropping signaling connection: conn_id %d (%s addr match, port differed)", target->conn_id, match_kind);
+
+		update_si_status(target, SCE_NP_SIGNALING_CONN_STATUS_INACTIVE, SCE_NP_SIGNALING_ERROR_TIMEOUT);
+	}
+	else
+	{
+		sign_log.warning("[P2PS] Peer timeout could not be matched to an active signaling connection");
+	}
+
+	work = take_deferred();
+	}
+	dispatch_deferred(work);
+}
+
+void signaling_handler::queue_force_disconnect(u32 addr, u16 port)
+{
+	// Called from the P2PS timeout monitor (a foreign thread). Record the dead endpoint and wake
+	// the signaling thread, which applies the disconnect in operator(). This thread must not take
+	// data_mutex - that lock belongs to the signaling thread alone.
+	{
+		std::lock_guard lock(m_pending_disc_mutex);
+		m_pending_disc.emplace_back(addr, port);
+	}
+	wake_up();
+}
