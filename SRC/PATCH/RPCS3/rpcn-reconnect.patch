diff --git a/rpcs3/Emu/NP/np_handler.cpp b/rpcs3/Emu/NP/np_handler.cpp
index 0d628e2..1884447 100644
--- a/rpcs3/Emu/NP/np_handler.cpp
+++ b/rpcs3/Emu/NP/np_handler.cpp
@@ -1108,6 +1108,270 @@ namespace np
 		while (thread_ctrl::state() != thread_state::aborting && !Emu.IsStopped())
 		{
 			bool sleep = true;
+
+			// === RPCN auto-reconnect ===========================================
+			// On a dropped connection rpcn_client sets connected=false but keeps
+			// authentified=true and is NOT destroyed, so this combination means
+			// "we were online and just lost the link".
+			if (is_psn_active && rpcn && rpcn->is_authentified() && !rpcn->is_connected())
+			{
+				rpcn_log.warning("RPCN reconnect: link lost while online (authentified && !connected); starting reconnect sequence");
+				rsx::overlays::queue_message(std::string("Connection to RPCN server lost, trying to reconnect..."));
+
+				// Initial grace delay before the first reconnect attempt. When the link
+				// drops the server tears down our old session asynchronously (Client::drop
+				// -> clean_user_state -> remove from client_infos). If we re-login faster
+				// than that cleanup finishes (e.g. low ping, ~100ms), the server still sees
+				// the old session and replies "already logged in", forcing a full retry
+				// cycle. Waiting ~5s lets the server-side cleanup complete first, so the
+				// very first login usually succeeds. 5s also gives enough room to toggle
+				// a VPN off/on manually during testing. The wait is interruptible so
+				// quitting the game stays responsive.
+				constexpr u64 initial_grace_us = 5'000'000;
+				rpcn_log.notice("RPCN reconnect: waiting %us grace before first attempt (let server free old session)", static_cast<u32>(initial_grace_us / 1'000'000));
+				for (u64 waited = 0; waited < initial_grace_us; waited += 500'000)
+				{
+					if (thread_ctrl::state() == thread_state::aborting || Emu.IsStopped())
+						break;
+					thread_ctrl::wait_for(500'000);
+				}
+
+				// Retry policy by failure category:
+				//  * connection-stage failure (network/VPN down): each attempt may
+				//    block for a while internally, so only a few tries before giving up.
+				//  * "already logged in": the server still holds our previous (silently
+				//    dropped) session as a ghost; it frees it after ~10 min. This is
+				//    transient and self-healing, so retry patiently.
+				//  * permanent login failure (bad user/password/token/protocol): never
+				//    retry, give up immediately.
+				// rpcn is NEVER left null here: get_rpcn() asserts on a null client in
+				// psn_rpcn mode, which would crash the title on its next NP call.
+				// Progressive backoff for connection-stage retries: 5 quick tries 5s apart,
+				// then 5 more 10s apart, then give up (~85s total). A failed connect attempt
+				// itself only costs ~1s, so short early gaps are cheap, and a brief VPN blip
+				// (a few seconds) recovers almost immediately without dropping in-match P2P.
+				// Outages longer than this are not something the title is expected to ride
+				// out. Ghost-session ("already logged in") retries keep their own patient
+				// cadence below, since the server frees the stale session on a ~10 min
+				// timeout and hammering it does not help.
+				static constexpr u64 connect_backoff_us[] = {5'000'000, 5'000'000, 5'000'000, 5'000'000, 5'000'000, 5'000'000, 10'000'000, 10'000'000, 10'000'000, 10'000'000, 10'000'000};
+				constexpr u32 max_connect_failures = static_cast<u32>(sizeof(connect_backoff_us) / sizeof(connect_backoff_us[0]));
+				constexpr u32 fast_phase_attempts  = 6; // first 6 retries use the short (5s) interval; the 7th+ wait 10s
+				constexpr u32 max_ghost_retries    = 2; // already-logged-in is usually a race with the server's async session cleanup, which the 2s initial grace already absorbs; one extra short retry covers a slow cleanup, and if it still fails it is a real ghost (no FIN, ~150s server keepalive) that cannot be waited out in-game, so go offline
+				constexpr u64 ghost_retry_delay_us = 5'000'000;
+				constexpr u64 sp_ghost_retry_delay_us = 15'000'000; // single-player: retry quietly every 15s, indefinitely
+				constexpr u64 mp_patient_retry_delay_us = 15'000'000; // multiplayer: same gentle cadence...
+				constexpr u64 mp_patient_max_us = 300'000'000; // ...but only up to 5 minutes total, then go offline
+				const u64 reconnect_started_us = get_system_time();
+
+				u32 connect_failures = 0;
+				u32 ghost_retries    = 0;
+				bool ghost_gave_up   = false;
+				bool sp_ghost_notified = false;
+				bool permanent_failure = false;
+				bool mp_patient_notified = false;
+				u64 next_delay_us    = connect_backoff_us[0];
+				bool reconnected     = false;
+				bool give_up         = false;
+
+				while (!give_up && thread_ctrl::state() != thread_state::aborting && !Emu.IsStopped())
+				{
+					// Build a fresh client. reset() must bring the use count to zero so
+					// get_instance() returns a brand new client; do it atomically and keep
+					// a local copy alive across the blocking calls below.
+					std::shared_ptr<rpcn::rpcn_client> local_rpcn;
+					{
+						std::lock_guard lock(mutex_rpcn);
+						rpcn.reset();
+						rpcn = rpcn::rpcn_client::get_instance(bind_ip);
+						local_rpcn = rpcn;
+					}
+
+					// --- stage 1: TCP + TLS connection ---
+					rpcn_log.notice("RPCN reconnect: connecting (connect_failures=%u, ghost_retries=%u)...", connect_failures, ghost_retries);
+					if (auto state = local_rpcn->wait_for_connection(); state != rpcn::rpcn_state::failure_no_failure)
+					{
+						connect_failures++;
+						rpcn_log.error("RPCN reconnect: stage 1 (connection) FAILED: %s [%u/%u]", rpcn::rpcn_state_to_string(state), connect_failures, max_connect_failures);
+						if (connect_failures >= max_connect_failures)
+						{
+							rpcn_log.error("RPCN reconnect: too many connection failures, giving up");
+							give_up = true;
+						}
+						else
+						{
+							// Notify once when we cross from the fast (5s) phase into the slow
+							// (10s) phase, instead of spamming a popup on every failed attempt.
+							if (connect_failures == fast_phase_attempts)
+							{
+								rsx::overlays::queue_message(std::string("RPCN fast reconnect failed, increasing retry interval..."));
+							}
+							next_delay_us = connect_backoff_us[connect_failures];
+						}
+					}
+					else
+					{
+						rpcn_log.success("RPCN reconnect: stage 1 (connection) OK");
+						connect_failures = 0;
+
+						// --- stage 2: login / authentication ---
+						rpcn_log.notice("RPCN reconnect: authenticating...");
+						const auto auth_state = local_rpcn->wait_for_authentified();
+						if (auth_state == rpcn::rpcn_state::failure_no_failure)
+						{
+							rpcn_log.success("RPCN reconnect: stage 2 (login) OK");
+
+							// --- stage 3: signaling (public address) ---
+							rpcn_log.notice("RPCN reconnect: requesting signaling info...");
+							const u32 new_public_addr = local_rpcn->get_addr_sig();
+							if (new_public_addr)
+							{
+								public_ip_addr = new_public_addr;
+								local_ip_addr  = std::bit_cast<u32, be_t<u32>>(local_rpcn->get_addr_local());
+								is_psn_active   = true;
+								rpcn_log.success("RPCN reconnect: stage 3 (signaling) OK, public_addr=0x%08x; FULLY RECONNECTED", new_public_addr);
+								rsx::overlays::queue_message(localized_string_id::RPCN_SUCCESS_LOGGED_ON);
+								reconnected = true;
+								break;
+							}
+
+							rpcn_log.error("RPCN reconnect: stage 3 (signaling) FAILED: no public address from server");
+							connect_failures++;
+							if (connect_failures >= max_connect_failures)
+							{
+								rpcn_log.error("RPCN reconnect: too many signaling failures, giving up");
+								give_up = true;
+							}
+							else
+							{
+								next_delay_us = connect_backoff_us[connect_failures];
+							}
+						}
+						else if (auth_state == rpcn::rpcn_state::failure_id_already_logged_in)
+						{
+							ghost_retries++;
+							rpcn_log.warning("RPCN reconnect: stage 2 (login) reports ALREADY LOGGED IN [%u/%u]; server still holds the old session (likely async-cleanup race / ghost).", ghost_retries, max_ghost_retries);
+							if (ghost_retries >= max_ghost_retries)
+							{
+								rpcn_log.error("RPCN reconnect: ghost session did not clear in time");
+								ghost_gave_up = true;
+								give_up = true;
+							}
+							else
+							{
+								next_delay_us = ghost_retry_delay_us;
+							}
+						}
+						else
+						{
+							rpcn_log.error("RPCN reconnect: stage 2 (login) PERMANENT failure: %s; giving up (won't retry bad credentials/protocol)", rpcn::rpcn_state_to_string(auth_state));
+							rsx::overlays::queue_message(rpcn::rpcn_state_to_localized_string_id(auth_state));
+							permanent_failure = true;
+							give_up = true;
+						}
+					}
+
+					// Patience override: when we would give up here for a NETWORK reason (dead
+					// link or ghost session), do not necessarily go offline. A ghost session
+					// on the server clears on its own (observed ~2 min), so if we keep PSN
+					// marked online and keep retrying, the link often comes back by itself.
+					// Permanent login failures (bad credentials/protocol) still give up.
+					if (give_up && !permanent_failure)
+					{
+						if (!np_cache.has_active_rooms())
+						{
+							// Single-player (free flight / campaign): the network layer is not
+							// needed for gameplay, and going offline would make the title show a
+							// "PSN connection lost" prompt and kick the player to the main menu
+							// mid-mission. Retry quietly forever (until the link returns or the
+							// player leaves). The player can finish the mission either way.
+							if (!sp_ghost_notified)
+							{
+								rpcn_log.warning("RPCN reconnect: link not restored, single-player (no active room); keeping PSN online and retrying quietly every %us until reconnected or emulation stops.", static_cast<u32>(sp_ghost_retry_delay_us / 1'000'000));
+								rsx::overlays::queue_message(std::string("RPCN reconnect error - still offline, but you are in single-player mode, continuing retries..."));
+								sp_ghost_notified = true;
+							}
+							else
+							{
+								rpcn_log.notice("RPCN reconnect: still offline (single-player), continuing quiet retries.");
+							}
+							give_up          = false;
+							ghost_gave_up    = false;
+							connect_failures = 0;
+							ghost_retries    = 0;
+							next_delay_us    = sp_ghost_retry_delay_us;
+						}
+						else if ((get_system_time() - reconnect_started_us) < mp_patient_max_us)
+						{
+							// Multiplayer (in a room): a short total-traffic outage can be ridden
+							// out if it stayed within the game's P2P tolerance (peers keep the
+							// match alive while we restore RPCN). The RPCN ghost session needs
+							// ~2 min to clear, so keep retrying patiently, but only up to a hard
+							// cap (5 min) -- beyond that the match is almost certainly gone and
+							// holding PSN "online" with a dead link only risks stalling NP calls.
+							if (!mp_patient_notified)
+							{
+								rpcn_log.warning("RPCN reconnect: link not restored, in a room; keeping PSN online and retrying every %us for up to %us (waiting out the server ghost session).", static_cast<u32>(mp_patient_retry_delay_us / 1'000'000), static_cast<u32>(mp_patient_max_us / 1'000'000));
+								rsx::overlays::queue_message(std::string("RPCN connection lost during a match, trying to recover..."));
+								mp_patient_notified = true;
+							}
+							else
+							{
+								rpcn_log.notice("RPCN reconnect: still offline (in a room), continuing retries (%us elapsed).", static_cast<u32>((get_system_time() - reconnect_started_us) / 1'000'000));
+							}
+							give_up          = false;
+							ghost_gave_up    = false;
+							connect_failures = 0;
+							ghost_retries    = 0;
+							next_delay_us    = mp_patient_retry_delay_us;
+						}
+						else
+						{
+							rpcn_log.error("RPCN reconnect: in a room but patience window (%us) elapsed without recovery; going offline.", static_cast<u32>(mp_patient_max_us / 1'000'000));
+							// fall through to the offline path below (give_up stays true).
+						}
+					}
+
+					if (reconnected || give_up)
+						break;
+
+					// Wait before the next attempt, staying responsive to shutdown.
+					rpcn_log.notice("RPCN reconnect: waiting %us before next attempt", static_cast<u32>(next_delay_us / 1'000'000));
+					for (u64 waited = 0; waited < next_delay_us; waited += 500'000)
+					{
+						if (thread_ctrl::state() == thread_state::aborting || Emu.IsStopped())
+							break;
+						thread_ctrl::wait_for(500'000);
+					}
+				}
+
+				if (!reconnected)
+				{
+					// Reached only when we either truly gave up (give_up) or the emulator is
+					// stopping. If we are stopping there is nothing to report and no point
+					// touching state. Otherwise keep the (disconnected) client object so
+					// get_rpcn() never sees null, and mark PSN offline so NP requests fail
+					// cleanly and the title returns to its menus. The game can re-establish
+					// PSN itself when the user next enters online mode.
+					if (give_up)
+					{
+						rpcn_log.error("RPCN reconnect: NOT reconnected; marking PSN offline (game will go offline gracefully)");
+						if (ghost_gave_up)
+						{
+							rsx::overlays::queue_message(std::string("RPCN error - user already logged in (ghost session), going offline"));
+						}
+						else
+						{
+							rsx::overlays::queue_message(std::string("RPCN reconnect failed - going offline"));
+						}
+						is_psn_active = false;
+					}
+				}
+
+				continue;
+			}
+			// === end RPCN auto-reconnect =======================================
+
 			if (rpcn)
 			{
 				std::lock_guard lock(mutex_rpcn);
